  "homepage": "https://myvergies.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/vergecurrency/VergeSlim.git"
  },
  "scripts": {
    "test": "npm run test:unit:ci",
    "test:unit": "jest --watchAll",
    "test:unit:ci": "jest --ci",
    "test:e2e": "vue-cli-service test:e2e",
    "lint": "vue-cli-service lint",
    "build:renderer": "cross-env MYVERGIES_DISABLE_BUILD_WORKERS=true vue-cli-service build",
    "build:main": "tsc -p tsconfig.electron.json && tsc-alias -p tsconfig.electron.json",
    "build:app": "rimraf dist_electron/bundled && npm run build:renderer && npm run build:main",
    "build:win-icon": "node scripts/generate-windows-icon.mjs",
    "docs:build": "node scripts/build-docs.mjs",
    "electron:build": "npm run build:app && npm run build:win-icon && electron-builder --config electron-builder.config.js",
    "electron:build:linux": "npm run electron:build -- --linux AppImage",
    "electron:build:win": "npm run electron:build -- --win portable",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "funding": [
