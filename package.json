{
  "name": "verge-slim",
  "description": "An electron-vue Verge Currency desktop wallet with Tor built in",
  "version": "26.5.0",
  "license": "MIT",
  "private": true,
  "author": {
    "email": "info@hdsign.nl",
    "name": "Swen van Zanten",
    "url": "https://github.com/swenvanzanten"
  },
  "bugs": {
    "url": "https://github.com/vergecurrency/VergeSlim/issues"
